#!/bin/bash
# ============================================================
# 星露谷物语 Mod 开发 - 路径配置
# ============================================================
# 使用方法：
#   cp paths.env.example paths.env
#   然后编辑 paths.env 中的路径为你的实际路径
# ============================================================

# --- 操作系统自动检测 ---
OS_TYPE="$(uname -s)"

# --- Stardew Valley 安装路径 ---
if [ "$OS_TYPE" = "Darwin" ]; then
    # macOS (Steam)
    STARDEW_HOME="$HOME/Library/Application Support/Steam/steamapps/common/Stardew Valley/Contents/MacOS"
elif [ "$OS_TYPE" = "Linux" ]; then
    # Linux (Steam)
    STARDEW_HOME="$HOME/.steam/steam/steamapps/common/Stardew Valley"
else
    # Windows (WSL / Git Bash)
    STARDEW_HOME="/mnt/c/Program Files (x86)/Steam/steamapps/common/Stardew Valley"
fi

# --- 核心路径 ---
MODS_DIR="$STARDEW_HOME/Mods"
SMAPI_BIN="$STARDEW_HOME/StardewModdingAPI"

# --- SMAPI 日志路径（按优先级尝试） ---
if [ "$OS_TYPE" = "Darwin" ]; then
    SMAPI_LOG_CANDIDATES=(
        "$STARDEW_HOME/ErrorLogs/SMAPI-latest.txt"
        "$HOME/.config/StardewValley/ErrorLogs/SMAPI-latest.txt"
        "$HOME/.local/share/StardewValley/ErrorLogs/SMAPI-latest.txt"
    )
elif [ "$OS_TYPE" = "Linux" ]; then
    SMAPI_LOG_CANDIDATES=(
        "$HOME/.config/StardewValley/ErrorLogs/SMAPI-latest.txt"
        "$HOME/.local/share/StardewValley/ErrorLogs/SMAPI-latest.txt"
        "$STARDEW_HOME/ErrorLogs/SMAPI-latest.txt"
    )
else
    SMAPI_LOG_CANDIDATES=(
        "$STARDEW_HOME/ErrorLogs/SMAPI-latest.txt"
    )
fi

# --- 辅助函数：查找 SMAPI 日志 ---
find_smapi_log() {
    for candidate in "${SMAPI_LOG_CANDIDATES[@]}"; do
        if [ -f "$candidate" ]; then
            echo "$candidate"
            return 0
        fi
    done
    # 返回第一个候选路径（即使不存在，等待 SMAPI 创建）
    echo "${SMAPI_LOG_CANDIDATES[0]}"
    return 1
}

# --- 获取 SKILL 包根目录（相对于此文件） ---
SKILLS_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
